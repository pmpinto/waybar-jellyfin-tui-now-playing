#!/usr/bin/env bash

status=$(playerctl -p jellyfin-tui status 2>/dev/null) || exit 0
[ "$status" = "Playing" ] || exit 0

artist=$(playerctl -p jellyfin-tui metadata --format '{{xesam:artist}}')
title=$(playerctl -p jellyfin-tui metadata --format '{{xesam:title}}')
album=$(playerctl -p jellyfin-tui metadata --format '{{xesam:album}}')
[ -n "$artist" ] && [ -n "$title" ] || exit 0

tooltip="<span alpha='72%'>¾░Āā Artist</span>   <span alpha='96%'>${artist}</span>\n<span alpha='72%'>¾░Ćź Album</span>    <span alpha='96%'>${album}</span>\n<span alpha='72%'>’Ćü Song</span>     <span alpha='96%'>${title}</span>"

printf '{"text":"’Ćü  %s","tooltip":"%s"}\n' "$artist" "$tooltip"
